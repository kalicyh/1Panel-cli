{
  "name": "1panel-cli",
  "version": "1.0.1",
  "description": "An AI-friendly CLI for deploying static websites to 1Panel.",
  "keywords": [
    "1Panel",
    "Static Website",
    "Deploy"
  ],
  "homepage": "https://github.com/kalicyh/1Panel-rocket-cli",
  "bugs": {
    "url": "https://github.com/kalicyh/1Panel-rocket-cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kalicyh/1Panel-rocket-cli.git"
  },
  "license": "MIT",
  "author": {
    "name": "Ryan Wang",
    "url": "https://github.com/ruibaby"
  },
  "type": "module",
  "main": "./bin/index.mjs",
  "bin": {
    "1panel-cli": "./bin/index.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin",
    "skills"
  ],
  "engines": {
    "node": ">=24 <26"
  },
  "scripts": {
    "build": "ncc build src/index.mjs -o bin",
    "check": "biome check src --fix --unsafe",
    "prepublish": "pnpm run build",
    "test:smoke": "node ./bin/index.mjs --help"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "commander": "^13.1.0",
    "form-data": "^4.0.2",
    "fs-extra": "^11.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@vercel/ncc": "^0.38.3",
    "prompts": "^2.4.2"
  },
  "packageManager": "pnpm@10.9.0"
}
